# Copy to .env and fill in. .env is gitignored.
#
# Generate strong values:
#   openssl rand -hex 32

# REQUIRED
MUNTRA_DB_PASSWORD=
MUNTRA_DASHBOARD_TOKEN=
MUNTRA_ALLOWED_SITES=mysite,othersite

# OPTIONAL — strongly recommended in production.
# Per-site Origin/Referer host allowlist. /collect rejects POSTs from
# elsewhere. Format: site_id:host1,host2|site_id:host3,...
# When unset for a site, validation is skipped for it.
# MUNTRA_SITE_ORIGINS=mysite:example.com,www.example.com|othersite:other.com

# OPTIONAL — bind on a non-localhost interface to expose Muntra directly
# without a reverse proxy. NOT recommended for production unless you know
# what you're doing (TLS, rate limits, etc. belong upstream).
# MUNTRA_HOST_PORT=0.0.0.0:8090

# OPTIONAL tuning (defaults shown)
# MUNTRA_FLUSH_INTERVAL=60s
# MUNTRA_FLUSH_BATCH_SIZE=500
# MUNTRA_ROLLUP_INTERVAL=15m
